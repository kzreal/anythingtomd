# Flask配置
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=True

# 文件上传配置
MAX_CONTENT_LENGTH=1073741824  # 1GB

# 下载文件路径
DOWNLOAD_FOLDER=/Users/kyle/Downloads

# LLM API配置（可选）
LLM_API_ENDPOINT=
LLM_API_KEY=
LLM_MODEL=vision-model
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
